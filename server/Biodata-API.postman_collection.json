                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"applied_position\": \"Full Stack Developer\",\n  \"full_name\": \"John Doe\",\n  \"id_number\": \"1234567890123456\",\n  \"birth_place\": \"Jakarta\",\n  \"birth_date\": \"1995-01-25\",\n  \"gender\": \"Male\",\n  \"religion\": \"Islam\",\n  \"blood_type\": \"A\",\n  \"marital_status\": \"Single\",\n  \"address_id\": \"Jl. Kebon Jeruk Raya No. 15, RT 001/RW 005, Kebon Jeruk, Jakarta Barat 11530\",\n  \"address_current\": \"Jl. Sudirman No. 88, Apt. Menteng Square Tower A Lt. 12, Jakarta Pusat 10220\",\n  \"personal_email\": \"john.doe@gmail.com\",\n  \"phone_number\": \"081234567890\",\n  \"emergency_contact\": \"081298765432\",\n  \"willing_to_relocate\": true,\n  \"expected_salary\": 18000000,\n  \"educations\": [\n    {\n      \"education_level\": \"Bachelor\",\n      \"institution_name\": \"Universitas Indonesia\",\n      \"major\": \"Teknik Informatika\",\n      \"graduation_year\": 2017,\n      \"gpa\": 3.7\n    },\n    {\n      \"education_level\": \"High School\",\n      \"institution_name\": \"SMA Negeri 1 Jakarta\",\n      \"major\": \"IPA\",\n      \"graduation_year\": 2013,\n      \"gpa\": 3.8\n    }\n  ],\n  \"trainings\": [\n    {\n      \"course_name\": \"Full Stack JavaScript Development\",\n      \"has_certificate\": true,\n      \"year\": 2023\n    },\n    {\n      \"course_name\": \"AWS Cloud Practitioner\",\n      \"has_certificate\": true,\n      \"year\": 2022\n    }\n  ],\n  \"work_experiences\": [\n    {\n      \"company_name\": \"PT. Teknologi Nusantara\",\n      \"last_position\": \"Senior Frontend Developer\",\n      \"last_salary\": 15000000,\n      \"last_year\": 2024\n    },\n    {\n      \"company_name\": \"CV. Digital Solusi\",\n      \"last_position\": \"Junior Full Stack Developer\",\n      \"last_salary\": 8500000,\n      \"last_year\": 2021\n    }\n  ],\n  \"skills\": [\n    {\n      \"skill_description\": \"Programming Languages: JavaScript, TypeScript, Python, PHP. Frontend: React.js, Vue.js, HTML5, CSS3, Bootstrap, Tailwind CSS. Backend: Node.js, Express.js, Laravel, Django. Database: MySQL, PostgreSQL, MongoDB. Tools: Git, Docker, AWS, Postman, VS Code.\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/profiles",
              "host": ["{{baseUrl}}"],
              "path": ["profiles"]
