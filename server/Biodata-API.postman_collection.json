              "raw": "{{baseUrl}}/profiles?name=john",
              "host": ["{{baseUrl}}"],
              "path": ["profiles"],
              "query": [
                {
                  "key": "name",
                  "value": "john",
                  "description": "Filter by full name (case insensitive, partial match)"
