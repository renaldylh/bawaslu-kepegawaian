      "item": [
        {
          "name": "Get My Profile (Full Data)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            },
            "description": "Get current authenticated user's complete profile including biodata, education, work experience, training, and skills."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Biodata Management",
      "item": [
        {
          "name": "Create Biodata (Complete)",
          "request": {
            "method": "POST",
            "header": [
