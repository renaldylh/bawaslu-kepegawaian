            "body": {
              "mode": "raw",
              "raw": "{\n  \"educations\": []\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/profiles/{{user_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["profiles", "{{user_id}}"]
            },
            "description": "Remove all education records by sending empty array. Works for trainings, work_experiences, and skills arrays too."
