            "body": {
              "mode": "raw",
              "raw": "{\n  \"applied_position\": \"Senior Full Stack Developer\",\n  \"full_name\": \"John Doe Updated\",\n  \"expected_salary\": 25000000,\n  \"marital_status\": \"Married\",\n  \"willing_to_relocate\": false,\n  \"educations\": [\n    {\n      \"education_level\": \"Master\",\n      \"institution_name\": \"Institut Teknologi Bandung\",\n      \"major\": \"Magister Teknik Informatika\",\n      \"graduation_year\": 2019,\n      \"gpa\": 3.8\n    }\n  ],\n  \"trainings\": [\n    {\n      \"course_name\": \"Advanced React & Next.js\",\n      \"has_certificate\": true,\n      \"year\": 2024\n    }\n  ],\n  \"work_experiences\": [\n    {\n      \"company_name\": \"PT. Tech Innovation\",\n      \"last_position\": \"Lead Developer\", \n      \"last_salary\": 22000000,\n      \"last_year\": 2024\n    }\n  ],\n  \"skills\": [\n    {\n      \"skill_description\": \"Advanced JavaScript, React.js, Next.js, Node.js, TypeScript, GraphQL, Docker, Kubernetes, AWS, Microservices Architecture.\"\n    }\n  ]\n}",
