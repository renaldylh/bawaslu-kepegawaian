          "name": "Get All Users - Filter by Position",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/profiles?position=developer",
              "host": ["{{baseUrl}}"],
              "path": ["profiles"],
              "query": [
                {
                  "key": "position",
                  "value": "developer",
                  "description": "Filter by applied position (case insensitive, partial match)"
                }
              ]
            },
            "description": "Filter users by applied position. Admin access required."
          },
          "response": []
        },
        {
          "name": "Get All Users - Filter by Education Level",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/profiles?educationLevel=Bachelor",
              "host": ["{{baseUrl}}"],
              "path": ["profiles"],
              "query": [
                {
                  "key": "educationLevel",
                  "value": "Bachelor",
                  "description": "Filter by education level (exact match)"
                }
              ]
            },
            "description": "Filter users by education level. Only returns users with that education level. Admin access required."
          },
          "response": []
        },
        {
          "name": "Get All Users - Combined Filters",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/profiles?name=john&position=developer&educationLevel=Bachelor",
              "host": ["{{baseUrl}}"],
              "path": ["profiles"],
              "query": [
                {
                  "key": "name",
                  "value": "john",
                  "description": "Filter by name"
                },
                {
                  "key": "position",
                  "value": "developer",
                  "description": "Filter by position"
                },
                {
                  "key": "educationLevel",
                  "value": "Bachelor",
                  "description": "Filter by education level"
                }
              ]
            },
            "description": "Combine multiple filters. Admin access required."
          },
          "response": []
        },
        {
          "name": "Get User by ID (Owner or Admin)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/profiles/{{user_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["profiles", "{{user_id}}"]
            },
            "description": "Get user by ID with complete biodata. User can only access their own data unless they are admin."
          },
          "response": []
        },
        {
          "name": "Delete User (Owner or Admin)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/profiles/{{user_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["profiles", "{{user_id}}"]
            },
            "description": "Delete user and all related biodata. User can only delete their own account unless they are admin."
          },
          "response": []
        }
      ]
    },
