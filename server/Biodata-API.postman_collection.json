              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"applied_position\": \"Software Engineer\",\n  \"full_name\": \"Jane Smith\",\n  \"id_number\": \"9876543210987654\",\n  \"birth_place\": \"Bandung\",\n  \"birth_date\": \"1990-05-15\",\n  \"gender\": \"Female\",\n  \"marital_status\": \"Single\",\n  \"address_id\": \"Jl. Merdeka No. 1, Bandung\",\n  \"address_current\": \"Jl. Sudirman No. 2, Jakarta\",\n  \"personal_email\": \"jane.smith@email.com\",\n  \"phone_number\": \"08123456789\",\n  \"willing_to_relocate\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/profiles",
